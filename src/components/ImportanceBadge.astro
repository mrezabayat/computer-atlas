---
interface Props {
  importance: "core" | "important" | "supplemental";
}

const { importance } = Astro.props;

const styles: Record<Props["importance"], { label: string; classes: string }> = {
  core: {
    label: "core",
    classes:
      "bg-rose-50 text-rose-800 border-rose-200 dark:bg-rose-950/40 dark:text-rose-200 dark:border-rose-900",
  },
  important: {
    label: "important",
    classes:
      "bg-amber-50 text-amber-800 border-amber-200 dark:bg-amber-950/40 dark:text-amber-200 dark:border-amber-900",
  },
  supplemental: {
    label: "supplemental",
    classes:
      "bg-slate-50 text-slate-700 border-slate-200 dark:bg-slate-800/40 dark:text-slate-300 dark:border-slate-700",
  },
};

const { label, classes } = styles[importance];
---

<span
  class:list={[
    "inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs font-medium",
    classes,
  ]}
  title={`Importance: ${label}`}
>
  {label}
</span>
