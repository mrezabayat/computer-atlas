---
import { loadGraph, pathUrl, topicUrl } from "~/lib/graph";

interface Props {
  topicId: string;
  pathIds: string[];
}

const { topicId, pathIds } = Astro.props;

if (pathIds.length === 0) {
  // Render nothing. Astro-style early return is via the {flag && ...} pattern
  // in the parent, but we also guard here so the component is safe to mount unconditionally.
}

const graph = await loadGraph();
const paths = pathIds
  .map((pid) => graph.paths.find((p) => p.id === pid))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const ctaHref = (pathId: string): string =>
  `${topicUrl(topicId)}?path=${encodeURIComponent(pathId)}`;
---

{
  paths.length > 0 && (
    <section
      class="not-prose mt-6 rounded-lg border border-[var(--color-atlas-accent)]/40 bg-[var(--color-atlas-accent-soft)] p-4"
      aria-label="Learning paths that include this topic"
    >
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="text-base font-semibold text-[var(--color-atlas-ink)]">
          Read this in a learning path
        </h2>
        <a
          href="/paths"
          class="text-xs text-[var(--color-atlas-accent)] no-underline hover:underline"
        >
          All paths →
        </a>
      </div>
      <p class="mt-1 text-sm text-[var(--color-atlas-muted)]">
        This topic is part of {paths.length === 1 ? "a learning path" : `${paths.length} learning paths`}.
        Start in context to keep prev/next and progress tracking.
      </p>
      <ul class="mt-3 grid gap-2 sm:grid-cols-2">
        {paths.map((p) => (
          <li>
            <a
              href={ctaHref(p.id)}
              class="block rounded-md border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] p-3 no-underline transition-colors hover:border-[var(--color-atlas-accent)]"
            >
              <span class="text-xs uppercase tracking-wide text-[var(--color-atlas-muted)]">
                Read this in
              </span>
              <span class="mt-0.5 block text-sm font-semibold text-[var(--color-atlas-ink)]">
                {p.data.title}
              </span>
              <span class="mt-1 block text-xs text-[var(--color-atlas-muted)] line-clamp-2">
                {p.data.summary}
              </span>
              <span class="mt-2 inline-flex items-center gap-1 text-xs text-[var(--color-atlas-accent)]">
                Start here
                <span aria-hidden="true">→</span>
              </span>
            </a>
            <a
              href={pathUrl(p.id)}
              class="mt-1 inline-block text-xs text-[var(--color-atlas-muted)] no-underline hover:underline"
            >
              View the whole path
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
