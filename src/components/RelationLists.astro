---
import { loadGraph, topicUrl, type TopicRelations } from "~/lib/graph";

interface Props {
  relations: TopicRelations;
}

const { relations } = Astro.props;
const graph = await loadGraph();

// Note: "Appears in" is intentionally NOT in this list. Path memberships are
// promoted to a separate AppearsInCard component above the neighborhood graph
// so they double as a discovery CTA, not just an "see also" entry.
const sections: Array<{ label: string; help: string; ids: string[] }> = [
  {
    label: "Requires",
    help: "Topics you should understand first.",
    ids: relations.prerequisites,
  },
  {
    label: "Related",
    help: "Topics that are conceptually nearby.",
    ids: relations.related,
  },
  {
    label: "Part of",
    help: "Larger topics this one belongs to.",
    ids: relations.partOf,
  },
  {
    label: "Contains",
    help: "Subtopics that are part of this one.",
    ids: relations.subtopics,
  },
  {
    label: "Next",
    help: "Where to go next, in suggested order.",
    ids: relations.nextSteps,
  },
  {
    label: "Leads to",
    help: "Topics that list this one as a next step.",
    ids: relations.leadsTo,
  },
  {
    label: "Required by",
    help: "Topics that depend on this one as a prerequisite.",
    ids: relations.requiredBy,
  },
];

const visibleSections = sections.filter((s) => s.ids.length > 0);

const resolveTopic = (id: string) => graph.topicsById.get(id);
---

<section
  aria-label="Relationships"
  class="not-prose rounded-lg border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] p-4"
>
  <h2 class="text-base font-semibold text-[var(--color-atlas-ink)]">
    Relationships
  </h2>
  {
    visibleSections.length === 0 ? (
      <p class="mt-2 text-sm text-[var(--color-atlas-muted)]">
        No relationships have been added for this topic yet.
      </p>
    ) : (
      <dl class="mt-3 grid gap-3 sm:grid-cols-2">
        {visibleSections.map((s) => (
          <div>
            <dt
              class="text-xs font-semibold uppercase tracking-wide text-[var(--color-atlas-muted)]"
              title={s.help}
            >
              {s.label}
            </dt>
            <dd class="mt-1">
              <ul class="flex flex-col gap-1 text-sm">
                {s.ids.map((id) => {
                  const t = resolveTopic(id);
                  if (!t) return null;
                  return (
                    <li>
                      <a href={topicUrl(t.id)} class="no-underline hover:underline">
                        {t.data.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </dd>
          </div>
        ))}
      </dl>
    )
  }
</section>
