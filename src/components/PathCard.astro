---
import type { CollectionEntry } from "astro:content";
import { pathUrl } from "~/lib/graph";
import PathProgressBar from "./PathProgressBar.tsx";

interface Props {
  path: CollectionEntry<"paths">;
  /** Optional: a few topic titles to preview as chips under the summary. */
  topicTitles?: string[];
  /** "compact" hides chips; "rich" shows them. Default rich. */
  variant?: "compact" | "rich";
}

const { path, topicTitles, variant = "rich" } = Astro.props;
const { title, summary, audience, topics, updated } = path.data;

const updatedLabel = updated.toISOString().slice(0, 10);
const previewChips =
  variant === "rich" ? (topicTitles ?? []).slice(0, 4) : [];
const extraCount =
  topicTitles && variant === "rich" ? Math.max(0, topicTitles.length - 4) : 0;

const audienceStyles: Record<typeof audience, string> = {
  beginner:
    "bg-emerald-50 text-emerald-800 border-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:border-emerald-900",
  intermediate:
    "bg-sky-50 text-sky-800 border-sky-200 dark:bg-sky-950/40 dark:text-sky-200 dark:border-sky-900",
  advanced:
    "bg-violet-50 text-violet-800 border-violet-200 dark:bg-violet-950/40 dark:text-violet-200 dark:border-violet-900",
};
---

<a
  href={pathUrl(path.id)}
  class="group flex h-full flex-col rounded-lg border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] p-5 no-underline transition-colors hover:border-[var(--color-atlas-accent)]"
>
  <div class="flex items-start justify-between gap-3">
    <h3
      class="text-lg font-semibold text-[var(--color-atlas-ink)] group-hover:text-[var(--color-atlas-accent)]"
    >
      {title}
    </h3>
    <span
      class:list={[
        "shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium",
        audienceStyles[audience],
      ]}
    >
      {audience}
    </span>
  </div>
  <p class="mt-2 text-sm text-[var(--color-atlas-muted)] line-clamp-3">
    {summary}
  </p>
  {
    previewChips.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5 text-xs text-[var(--color-atlas-muted)]">
        {previewChips.map((t) => (
          <li class="rounded-full border border-[var(--color-atlas-line)] bg-[var(--color-atlas-bg)] px-2 py-0.5">
            {t}
          </li>
        ))}
        {extraCount > 0 && (
          <li class="rounded-full border border-transparent px-2 py-0.5">
            +{extraCount} more
          </li>
        )}
      </ul>
    )
  }
  <div
    class="mt-auto flex items-baseline justify-between gap-2 pt-4 text-xs text-[var(--color-atlas-muted)]"
  >
    <span>{topics.length} topics</span>
    <span>Updated {updatedLabel}</span>
  </div>
  <PathProgressBar client:idle pathId={path.id} />
</a>
