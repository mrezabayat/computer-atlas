---
import "~/styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteName = "Computer Atlas";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const defaultDescription =
  "A browsable, searchable map of computer science and computing topics — built for beginners, students, and curious engineers.";
const finalDescription = description ?? defaultDescription;
const canonicalUrl = canonical
  ? new URL(canonical, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Computer Atlas — recently updated topics"
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Set theme before paint to avoid FOUC. Stored choice wins over OS pref.
      try {
        const stored = localStorage.getItem("atlas-theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme = stored === "light" || stored === "dark"
          ? stored
          : prefersDark
            ? "dark"
            : "light";
        document.documentElement.dataset.theme = theme;
      } catch (_) {
        // Storage may be blocked; fall back to default light theme.
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header
      class="border-b border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)]"
    >
      <div
        class="mx-auto max-w-6xl px-4 py-4 flex items-center justify-between gap-6"
      >
        <a
          href="/"
          class="text-lg font-semibold text-[var(--color-atlas-ink)] no-underline hover:no-underline"
        >
          Computer&nbsp;Atlas
        </a>
        <nav class="flex items-center gap-5 text-sm">
          <a href="/" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">Browse</a>
          <a href="/atlas" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">Atlas</a>
          <a href="/topics" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">A–Z</a>
          <a href="/paths" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">Paths</a>
          <a href="/search" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">Search</a>
          <a href="/about" class="text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)] no-underline">About</a>
          <button
            type="button"
            id="theme-toggle"
            class="ml-2 inline-flex h-8 w-8 items-center justify-center rounded-md border border-[var(--color-atlas-line)] text-[var(--color-atlas-muted)] hover:text-[var(--color-atlas-ink)]"
            aria-label="Toggle dark mode"
            title="Toggle dark mode"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="hidden dark:block"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="block dark:hidden"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer
      class="border-t border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] mt-12"
    >
      <div
        class="mx-auto max-w-6xl px-4 py-6 text-sm text-[var(--color-atlas-muted)] flex flex-wrap items-center justify-between gap-3"
      >
        <span>
          A field guide to the computing world. Content is open and editable.
        </span>
        <span>
          <a href="/contribute" class="no-underline hover:underline">Contribute</a>
          {" · "}
          <a href="/about" class="no-underline hover:underline">About</a>
          {" · "}
          <a href="/rss.xml" class="no-underline hover:underline">RSS</a>
        </span>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", () => {
          const root = document.documentElement;
          const next = root.dataset.theme === "dark" ? "light" : "dark";
          root.dataset.theme = next;
          try {
            localStorage.setItem("atlas-theme", next);
          } catch (_) {
            // Storage may be blocked; the change still applies for this session.
          }
        });
      })();
    </script>
  </body>
</html>
