---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import StatusBadge from "~/components/StatusBadge.astro";
import KindBadge from "~/components/KindBadge.astro";
import LevelBadge from "~/components/LevelBadge.astro";
import ImportanceBadge from "~/components/ImportanceBadge.astro";
import RelationLists from "~/components/RelationLists.astro";
import AppearsInCard from "~/components/AppearsInCard.astro";
import NeighborhoodGraph from "~/components/NeighborhoodGraph.tsx";
import PathContextStrip from "~/components/PathContextStrip.tsx";
import InlineMarkComplete from "~/components/InlineMarkComplete.tsx";
import { getTopicRelations, getNeighborGraph, categoryUrl } from "~/lib/graph";
import { buildPathContexts } from "~/lib/path-contexts";
import { topicReadingTimeMinutes } from "~/lib/reading-time";
import { categoryLabel, type CategorySlug } from "~/lib/categories";
import { editUrl, reportFixUrl } from "~/site.config";

interface Props {
  topic: CollectionEntry<"topics">;
}

const { topic } = Astro.props;
const { title, summary, kind, level, status, importance, category, updated, aliases } =
  topic.data;
const relations = (await getTopicRelations(topic.id)) ?? {
  prerequisites: [],
  related: [],
  partOf: [],
  nextSteps: [],
  subtopics: [],
  leadsTo: [],
  requiredBy: [],
  appearsInRoadmaps: [],
};
const neighborGraph = await getNeighborGraph(topic.id);
const pathContexts = await buildPathContexts(
  topic.id,
  relations.appearsInRoadmaps,
);

const editHref = topic.filePath ? editUrl(topic.filePath) : reportFixUrl({ topicId: topic.id });
const reportHref = reportFixUrl({ topicId: topic.id });
const updatedLabel = updated.toISOString().slice(0, 10);
const tags = topic.data.tags ?? [];
const categoryDisplay = categoryLabel(category as CategorySlug);
const readingMinutes = topicReadingTimeMinutes(topic);
---

<BaseLayout title={title} description={summary}>
  <article
    class="mx-auto max-w-3xl px-4 py-8"
    data-pagefind-body
  >
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-filter={`category:${categoryDisplay}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-filter={`kind:${kind}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-filter={`level:${level}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-filter={`status:${status}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-filter={`importance:${importance}`}
    ></span>
    {
      tags.map((tag) => (
        <span
          class="hidden"
          aria-hidden="true"
          data-pagefind-filter={`tag:${tag}`}
        />
      ))
    }
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-meta={`category:${category}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-meta={`kind:${kind}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-meta={`level:${level}`}
    ></span>
    <span
      class="hidden"
      aria-hidden="true"
      data-pagefind-meta={`importance:${importance}`}
    ></span>
    {pathContexts.length > 0 && (
      <PathContextStrip client:load pathContexts={pathContexts} />
    )}

    <nav
      class="text-xs text-[var(--color-atlas-muted)]"
      aria-label="Breadcrumb"
    >
      <a href="/" class="no-underline hover:underline">Atlas</a>
      <span aria-hidden="true"> / </span>
      <a
        href={categoryUrl(category)}
        class="no-underline hover:underline"
      >
        {categoryLabel(category as CategorySlug)}
      </a>
    </nav>

    <header class="mt-2">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]"
      >
        {title}
      </h1>
      {aliases.length > 0 && (
        <p class="mt-1 text-sm italic text-[var(--color-atlas-muted)]">
          Also known as: {aliases.join(", ")}
        </p>
      )}
      <div class="mt-3 flex flex-wrap items-center gap-2">
        {importance !== "important" && <ImportanceBadge importance={importance} />}
        <LevelBadge level={level} />
        <KindBadge kind={kind} />
        {status !== "reviewed" && <StatusBadge status={status} />}
        <span class="text-xs text-[var(--color-atlas-muted)]">
          {readingMinutes} min read · Updated {updatedLabel}
        </span>
      </div>
      <p class="mt-4 text-lg text-[var(--color-atlas-ink)]">
        {summary}
      </p>
    </header>

    <div
      class="prose prose-slate dark:prose-invert prose-headings:scroll-mt-24 prose-headings:font-semibold prose-h2:mt-10 prose-h2:text-xl prose-a:text-[var(--color-atlas-accent)] mt-8 max-w-none"
    >
      <slot />
    </div>

    {relations.appearsInRoadmaps.length > 0 && (
      <div class="mt-10">
        <AppearsInCard
          topicId={topic.id}
          pathIds={relations.appearsInRoadmaps}
        />
      </div>
    )}

    <div class={relations.appearsInRoadmaps.length > 0 ? "mt-6" : "mt-10"}>
      <RelationLists relations={relations} />
    </div>

    {
      neighborGraph.nodes.length > 1 && (
        <section class="not-prose mt-6" aria-label="Neighborhood graph">
          <h2 class="text-base font-semibold text-[var(--color-atlas-ink)]">
            Neighborhood
          </h2>
          <p class="mt-1 text-sm text-[var(--color-atlas-muted)]">
            A visual companion to the relationships above. Click any node to
            visit that topic.
          </p>
          <div class="mt-3">
            <NeighborhoodGraph
              client:visible
              centerId={topic.id}
              graph={neighborGraph}
            />
          </div>
        </section>
      )
    }

    {pathContexts.length > 0 && (
      <InlineMarkComplete
        client:load
        topicId={topic.id}
        pathContexts={pathContexts}
      />
    )}

    <footer
      class="mt-10 border-t border-[var(--color-atlas-line)] pt-4 text-sm text-[var(--color-atlas-muted)] flex flex-wrap gap-x-4 gap-y-1"
    >
      <a
        href={editHref}
        target="_blank"
        rel="noopener noreferrer"
        class="no-underline hover:underline"
      >
        Edit on GitHub
      </a>
      <a
        href={reportHref}
        target="_blank"
        rel="noopener noreferrer"
        class="no-underline hover:underline"
      >
        Report a fix
      </a>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  /* React Flow controls — make the +/-/fit-view buttons honour the dark theme. */
  :root[data-theme="dark"] .react-flow__controls {
    box-shadow: none;
  }
  :root[data-theme="dark"] .react-flow__controls-button {
    background: var(--color-atlas-surface);
    border-bottom: 1px solid var(--color-atlas-line);
    color: var(--color-atlas-ink);
  }
  :root[data-theme="dark"] .react-flow__controls-button:hover {
    background: var(--color-atlas-accent-soft);
  }
  :root[data-theme="dark"] .react-flow__controls-button svg,
  :root[data-theme="dark"] .react-flow__controls-button path {
    fill: var(--color-atlas-ink);
  }
</style>
