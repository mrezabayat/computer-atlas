---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAllTopics, topicUrl } from "~/lib/graph";
import { categoryLabel, type CategorySlug } from "~/lib/categories";

const topics = await getAllTopics();

const sorted = [...topics].sort((a, b) =>
  a.data.title.localeCompare(b.data.title, "en", { sensitivity: "base" }),
);

const firstLetter = (title: string): string => {
  const ch = title.trim().charAt(0).toUpperCase();
  return /[A-Z]/.test(ch) ? ch : "#";
};

const groups = new Map<string, typeof sorted>();
for (const t of sorted) {
  const k = firstLetter(t.data.title);
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(t);
}

const letters = [...groups.keys()].sort();
---

<BaseLayout
  title="All topics"
  description="Every topic in CS Map, A to Z."
>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <nav class="text-xs text-[var(--color-atlas-muted)]" aria-label="Breadcrumb">
      <a href="/" class="no-underline hover:underline">Atlas</a>
    </nav>
    <header class="mt-2">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]"
      >
        All topics
      </h1>
      <p class="mt-3 text-lg text-[var(--color-atlas-muted)] max-w-3xl">
        Every topic in the atlas, in alphabetical order. {topics.length} topics.
      </p>
      <nav
        aria-label="Jump to letter"
        class="mt-4 flex flex-wrap gap-1 text-sm"
      >
        {
          letters.map((l) => (
            <a
              href={`#letter-${l}`}
              class="rounded border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] px-2 py-0.5 text-[var(--color-atlas-muted)] no-underline hover:border-[var(--color-atlas-accent)] hover:text-[var(--color-atlas-accent)]"
            >
              {l}
            </a>
          ))
        }
      </nav>
    </header>

    <div class="mt-8 space-y-8">
      {
        letters.map((l) => (
          <section id={`letter-${l}`} class="scroll-mt-24">
            <h2 class="text-xl font-bold text-[var(--color-atlas-ink)]">{l}</h2>
            <ul class="mt-2 divide-y divide-[var(--color-atlas-line)] rounded-md border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)]">
              {groups.get(l)!.map((t) => (
                <li class="flex flex-col gap-1 px-4 py-2 sm:flex-row sm:items-baseline sm:gap-4">
                  <a
                    href={topicUrl(t.id)}
                    class="text-sm font-medium text-[var(--color-atlas-ink)] no-underline hover:underline sm:w-56"
                  >
                    {t.data.title}
                  </a>
                  <span
                    class="text-xs text-[var(--color-atlas-muted)] line-clamp-1 flex-1"
                    title={t.data.summary}
                  >
                    {t.data.summary}
                  </span>
                  <span class="shrink-0 text-xs text-[var(--color-atlas-muted)]">
                    {categoryLabel(t.data.category as CategorySlug)}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
