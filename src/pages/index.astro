---
import BaseLayout from "~/layouts/BaseLayout.astro";
import CategoryGrid from "~/components/CategoryGrid.astro";
import TopicCard from "~/components/TopicCard.astro";
import PathCard from "~/components/PathCard.astro";
import ContinueLearning from "~/components/ContinueLearning.tsx";
import { loadGraph, getAllTopics, getAllPaths } from "~/lib/graph";
import { pathTopicIds } from "~/lib/paths";

const topics = await getAllTopics();
const recentTopics = [...topics]
  .sort((a, b) => b.data.updated.getTime() - a.data.updated.getTime())
  .slice(0, 6);
const paths = await getAllPaths();
const featuredPaths = paths.slice(0, 6);

const { topicsById } = await loadGraph();
const titleListForPath = (
  path: (typeof featuredPaths)[number],
): string[] =>
  pathTopicIds(path.data.topics)
    .map((id) => topicsById.get(id)?.data.title)
    .filter((t): t is string => Boolean(t));
---

<BaseLayout title="CS Map">
  <section class="bg-[var(--color-atlas-surface)] border-b border-[var(--color-atlas-line)]">
    <div class="mx-auto max-w-4xl px-4 py-12 text-center">
      <h1
        class="text-4xl font-bold tracking-tight text-[var(--color-atlas-ink)] sm:text-5xl"
      >
        A field guide to computing.
      </h1>
      <p
        class="mt-3 text-lg text-[var(--color-atlas-muted)] mx-auto max-w-2xl"
      >
        Browsable, searchable explanations of computer science and computing
        topics — what they mean, where they belong, what to learn before, and
        what to learn next.
      </p>
      <form
        action="/search"
        method="get"
        class="mt-6 mx-auto flex max-w-xl gap-2"
      >
        <label for="q" class="sr-only">Search the atlas</label>
        <input
          id="q"
          name="q"
          type="search"
          placeholder="Search topics, e.g. 'cpu', 'dns', 'algorithms'…"
          class="flex-1 rounded-md border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] px-3 py-2 text-base text-[var(--color-atlas-ink)] focus:outline-none focus:ring-2 focus:ring-[var(--color-atlas-accent)]"
        />
        <button
          type="submit"
          class="rounded-md bg-[var(--color-atlas-accent)] px-4 py-2 text-sm font-medium text-white"
        >
          Search
        </button>
      </form>
    </div>
  </section>

  <ContinueLearning client:load />

  {
    featuredPaths.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-10">
        <div class="flex items-baseline justify-between">
          <h2 class="text-xl font-semibold text-[var(--color-atlas-ink)]">
            Learning paths
          </h2>
          <a
            href="/paths"
            class="text-sm text-[var(--color-atlas-accent)] no-underline hover:underline"
          >
            See all {paths.length} →
          </a>
        </div>
        <p class="mt-1 text-sm text-[var(--color-atlas-muted)] max-w-2xl">
          Guided sequences of topics designed to be read in order. Best when you want a structured tour rather than to browse.
        </p>
        <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuredPaths.map((p) => (
            <li>
              <PathCard path={p} topicTitles={titleListForPath(p)} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 py-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xl font-semibold text-[var(--color-atlas-ink)]">
        Browse by category
      </h2>
      <span class="text-sm text-[var(--color-atlas-muted)]">16 categories</span>
    </div>
    <p class="mt-1 text-sm text-[var(--color-atlas-muted)] max-w-2xl">
      Prefer to wander by subject? Every topic in the atlas also lives in one of the 16 top-level categories.
    </p>
    <div class="mt-5">
      <CategoryGrid />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xl font-semibold text-[var(--color-atlas-ink)]">
        Recently updated
      </h2>
      <span class="text-sm text-[var(--color-atlas-muted)]">
        {topics.length} topics in the atlas
      </span>
    </div>
    <ul class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {recentTopics.map((t) => <li><TopicCard topic={t} /></li>)}
    </ul>
  </section>
</BaseLayout>
