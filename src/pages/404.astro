---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="That page does not exist.">
  <div class="mx-auto max-w-2xl px-4 py-16 text-center">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]">
      Off the map
    </h1>
    <p class="mt-3 text-[var(--color-atlas-muted)]">
      That topic does not exist in the atlas yet.
    </p>
    <p class="mt-6">
      <a
        href="/"
        class="rounded-md bg-[var(--color-atlas-accent)] px-4 py-2 text-sm font-medium text-white no-underline"
        >Back to the atlas</a
      >
    </p>
  </div>
</BaseLayout>
