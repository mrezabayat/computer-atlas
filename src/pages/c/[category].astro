---
import { getEntry, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import TopicCard from "~/components/TopicCard.astro";
import { CATEGORIES } from "~/lib/categories";
import { getTopicsByCategory } from "~/lib/graph";
import { newTopicIssueUrl } from "~/site.config";

export async function getStaticPaths() {
  return CATEGORIES.map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params as { category: (typeof CATEGORIES)[number] };
const categoryEntry = await getEntry("categories", category);
if (!categoryEntry) {
  throw new Error(`Missing category content file for ${category}`);
}

const topics = await getTopicsByCategory(category);

const byLevel = ["beginner", "intermediate", "advanced"].map((level) => ({
  level,
  topics: topics
    .filter((t) => t.data.level === level)
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));

const { Content: CategoryBody } = await render(categoryEntry);
---

<BaseLayout
  title={categoryEntry.data.title}
  description={categoryEntry.data.summary}
>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <nav class="text-xs text-[var(--color-atlas-muted)]" aria-label="Breadcrumb">
      <a href="/" class="no-underline hover:underline">Atlas</a>
    </nav>
    <header class="mt-2">
      <div class="flex items-center gap-3">
        {categoryEntry.data.icon && (
          <span
            class="text-2xl text-[var(--color-atlas-muted)]"
            aria-hidden="true"
          >
            {categoryEntry.data.icon}
          </span>
        )}
        <h1
          class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]"
        >
          {categoryEntry.data.title}
        </h1>
      </div>
      <p class="mt-3 text-lg text-[var(--color-atlas-muted)] max-w-3xl">
        {categoryEntry.data.summary}
      </p>
    </header>

    <div class="prose prose-slate dark:prose-invert mt-6 max-w-none">
      <CategoryBody />
    </div>

    {topics.length === 0 ? (
      <p class="mt-8 rounded-lg border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] p-4 text-sm text-[var(--color-atlas-muted)]">
        No topics in this category yet. Want to add one?{" "}
        <a
          href={newTopicIssueUrl({ category })}
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline hover:underline"
        >
          Suggest one on GitHub
        </a>.
      </p>
    ) : (
      <div class="mt-8 space-y-8">
        {byLevel.map(
          (group) =>
            group.topics.length > 0 && (
              <section>
                <h2 class="text-base font-semibold uppercase tracking-wide text-[var(--color-atlas-muted)]">
                  {group.level}
                </h2>
                <ul class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {group.topics.map((t) => (
                    <li>
                      <TopicCard topic={t} showCategory={false} />
                    </li>
                  ))}
                </ul>
              </section>
            ),
        )}
      </div>
    )}
  </div>
</BaseLayout>
