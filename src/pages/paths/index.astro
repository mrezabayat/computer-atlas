---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PathCard from "~/components/PathCard.astro";
import { loadGraph, getAllPaths } from "~/lib/graph";
import { pathTopicIds } from "~/lib/paths";

const paths = await getAllPaths();
const { topicsById } = await loadGraph();

const titleListForPath = (path: (typeof paths)[number]): string[] =>
  pathTopicIds(path.data.topics)
    .map((id) => topicsById.get(id)?.data.title)
    .filter((t): t is string => Boolean(t));

const byAudience = ["beginner", "intermediate", "advanced"].map((audience) => ({
  audience,
  paths: paths
    .filter((p) => p.data.audience === audience)
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));
---

<BaseLayout
  title="Learning paths"
  description="Curated, ordered tours through computer science topics."
>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <nav class="text-xs text-[var(--color-atlas-muted)]" aria-label="Breadcrumb">
      <a href="/" class="no-underline hover:underline">Atlas</a>
    </nav>
    <header class="mt-2">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]"
      >
        Learning paths
      </h1>
      <p class="mt-3 text-lg text-[var(--color-atlas-muted)] max-w-3xl">
        Curated, ordered tours through the atlas. Each path is a sequence of
        topics that build on each other — start the first topic and the prev /
        next navigation, progress tracking, and "mark complete" follow you the
        whole way.
      </p>
      <p class="mt-2 text-sm text-[var(--color-atlas-muted)]">
        {paths.length} paths · grouped by audience.
      </p>
    </header>

    {paths.length === 0 ? (
      <p class="mt-8 text-sm text-[var(--color-atlas-muted)]">
        No learning paths have been added yet.
      </p>
    ) : (
      <div class="mt-8 space-y-10">
        {byAudience.map(
          (group) =>
            group.paths.length > 0 && (
              <section>
                <div class="flex items-baseline justify-between gap-2">
                  <h2 class="text-base font-semibold uppercase tracking-wide text-[var(--color-atlas-muted)]">
                    For {group.audience}s
                  </h2>
                  <span class="text-xs text-[var(--color-atlas-muted)]">
                    {group.paths.length} paths
                  </span>
                </div>
                <ul class="mt-4 grid gap-4 sm:grid-cols-2">
                  {group.paths.map((p) => (
                    <li>
                      <PathCard
                        path={p}
                        topicTitles={titleListForPath(p)}
                      />
                    </li>
                  ))}
                </ul>
              </section>
            ),
        )}
      </div>
    )}
  </div>
</BaseLayout>
